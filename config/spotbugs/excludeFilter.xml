<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
<!-- Exclude test classes -->
<Match>
    <Class name="~.*Test$"/>
</Match>

<!-- Exclude generated code -->
<Match>
    <Package name="~.*\.generated\..*"/>
</Match>

<!-- Exclude Lombok generated code -->
<Match>
    <Class name="~.*\$.*"/>
</Match>
</FindBugsFilter>